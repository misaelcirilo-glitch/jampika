# URL del backend Express. En producción DEBE apuntar al dominio real del API
# (p.ej. https://api.jampika.com/api/v1). Si se deja en localhost, el login
# fallará con "No se pudo conectar con el servidor" desde el sitio desplegado.
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
NEXT_PUBLIC_APP_NAME="Jampika"

# Muestra credenciales demo y prellena el login. Solo para desarrollo.
# En producción déjalo sin definir (o "false").
NEXT_PUBLIC_DEMO_MODE="true"
